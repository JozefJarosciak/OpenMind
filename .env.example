# OpenMind for OpenClaw — Docker Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env

# REQUIRED: Path to your OpenClaw workspace on the host machine
OPENMIND_WORKSPACE=/root/.openclaw/workspace

# REQUIRED: Admin password (8+ chars, upper, lower, number, special char)
OPENMIND_ADMIN_PASS=

# Optional: Admin username (default: admin)
OPENMIND_ADMIN_USER=admin

# Optional: Port to expose (default: 8080)
OPENMIND_PORT=8080

# Optional: App title
OPENMIND_TITLE=OpenMind

# Optional: OpenClaw settings
OPENMIND_OPENCLAW_CMD=/usr/bin/openclaw
OPENMIND_OPENCLAW_AGENT=main
OPENMIND_OPENCLAW_RUN_AS=

# Optional: Network restriction (none, tailscale, custom)
OPENMIND_NETWORK=none
OPENMIND_ALLOWED_IPS=
